{
  "name": "locus",
  "version": "4.2.3",
  "description": "OS-level AI code reviewer \u2014 select any text, get staff-engineer analysis",
  "homepage": "https://github.com/NovasPlace/Locus",
  "main": "src/main.js",
  "author": {
    "name": "Donovan Everitts",
    "email": "donovan@sovereignforge.dev"
  },
  "license": "MIT",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron . --no-sandbox",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.locus.agent",
    "productName": "Locus",
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icons",
      "desktop": {
        "entry": {
          "StartupWMClass": "locus"
        }
      }
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "publish": {
      "provider": "github",
      "owner": "NovasPlace",
      "repo": "Locus"
    }
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^17.0.4",
    "marked-highlight": "^2.2.3"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.0.0"
  }
}